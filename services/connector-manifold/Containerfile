# services/connector-manifold/Containerfile
#
# NOTE: In the current architecture, connector-manifold is a Python package
# imported directly by the scheduler rather than a standalone service.
# This Containerfile is used for CI testing and future standalone extraction.
#
# Usage:
#   podman build -t tiresias-connector-manifold .
#   podman run --rm tiresias-connector-manifold

FROM python:3.12-slim AS base

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY connector_manifold/ ./connector_manifold/
COPY tests/ ./tests/

RUN adduser --disabled-password --gecos "" appuser
USER appuser

ENV MANIFOLD_API_KEY=""
ENV MANIFOLD_API_BASE="https://api.manifold.markets/v0"

CMD ["pytest", "tests/", "-v"]
