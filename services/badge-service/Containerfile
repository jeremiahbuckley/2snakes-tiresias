# services/badge-service/Containerfile
#
# Runs the badge-service FastAPI app via uvicorn.
# Mounts at /badges — intended to be included in the api-gateway,
# but can also run standalone for local development.
#
# Usage:
#   podman build -t tiresias-badge-service .
#   podman run --rm -p 8001:8001 \
#     -e DATABASE_URL=postgresql+asyncpg://user:pass@db:5432/tiresias \
#     tiresias-badge-service

FROM python:3.12-slim AS base

WORKDIR /app

COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

COPY badge_service/ ./badge_service/
COPY tests/ ./tests/

RUN adduser --disabled-password --gecos "" appuser
USER appuser

ENV PORT=8001
ENV DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/tiresias

EXPOSE 8001

HEALTHCHECK --interval=15s --timeout=5s --start-period=10s --retries=3 \
    CMD python -c "import urllib.request; urllib.request.urlopen('http://localhost:8001/badges/')"

CMD ["uvicorn", "badge_service.api:router", "--host", "0.0.0.0", "--port", "8001"]
