# ============================================================
# Tiresias — API credentials template
# ============================================================
# Copy this file to .env and fill in your real values.
#   cp .env.example .env
# The .env file is gitignored and should never be committed.
# ============================================================

# ── Kalshi ──────────────────────────────────────────────────
# Docs: https://docs.kalshi.com/welcome
# Auth: RSA-PSS request signing — NOT a simple bearer token.
# 1. Go to https://kalshi.com/account/profile → API Keys → Create New API Key
# 2. Save the downloaded .key file somewhere safe (e.g. ~/.kalshi/kalshi.key)
# 3. Copy the Key ID (UUID shown after generation) into KALSHI_KEY_ID
# 4. Set KALSHI_PRIVATE_KEY_PATH to the absolute path of your saved .key file
KALSHI_KEY_ID=
KALSHI_PRIVATE_KEY_PATH=
# KALSHI_API_BASE=https://demo-api.kalshi.co/trade-api/v2   # uncomment for sandbox

# ── Polymarket ──────────────────────────────────────────────
# Docs: https://docs.polymarket.com
# No API key required — Gamma and Data APIs are fully public.
# Set POLYMARKET_WALLET_ADDRESS to the user's Polygon proxy wallet address
# (visible at polymarket.com/settings). Used to query trade/position history.
POLYMARKET_WALLET_ADDRESS=
# POLYMARKET_GAMMA_BASE=https://gamma-api.polymarket.com
# POLYMARKET_DATA_BASE=https://data-api.polymarket.com

# ── Manifold Markets ────────────────────────────────────────
# Docs: https://docs.manifold.markets/api
# Header: Authorization: Key <token>
MANIFOLD_API_KEY=
# MANIFOLD_API_BASE=https://api.manifold.markets/v0

# ── Metaculus ───────────────────────────────────────────────
# Docs: https://www.metaculus.com/api2/
# Header: Authorization: Token <token>
# Public GET endpoints work without auth; higher rate limits with token.
METACULUS_TOKEN=
# METACULUS_API_BASE=https://www.metaculus.com/api2
