# Temporary placeholder — serves a stub HTML response
RUN echo '<!DOCTYPE html><html><body><h1>user-dashboard (placeholder)</h1></body></html>' > /app/index.html

FROM node:20-slim AS runtime

WORKDIR /app
COPY --from=builder /app/index.html .

ENV PORT=3000
EXPOSE 3000

# TODO: replace with proper static server (nginx, serve, etc.)
CMD ["node", "-e", "require('http').createServer((_,r)=>{r.end(require('fs').readFileSync('index.html'))}).listen(process.env.PORT||3000)"]
